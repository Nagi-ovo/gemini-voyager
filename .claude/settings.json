{
  "permissions": {
    "deny": [
      "Read(./.entire/metadata/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-before-push.sh",
            "if": "Bash(git push*)",
            "statusMessage": "Formatting outgoing files before push"
          }
        ]
      }
    ]
  }
}
